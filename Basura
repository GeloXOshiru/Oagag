                        UpdateColor()
                    elseif draggingHue then
                        hue = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
                        UpdateColor()
                    end
                end
            end)
            Header.MouseButton1Click:Connect(function()
                pickerOpen = not pickerOpen
                if pickerOpen then
                    Tween(Container, {Size = UDim2.new(1, 0, 0, 34 + 148)}, TweenInfo_Default)
                    Tween(PickerPanel, {Size = UDim2.new(1, 0, 0, 144)}, TweenInfo_Default)
                else
                    Tween(Container, {Size = UDim2.new(1, 0, 0, 34)}, TweenInfo_Default)
                    Tween(PickerPanel, {Size = UDim2.new(1, 0, 0, 0)}, TweenInfo_Default)
                end
            end)
            Header.MouseEnter:Connect(function() Tween(Container, {BackgroundColor3 = Theme.ElementHover}, TweenInfo_Fast) end)
            Header.MouseLeave:Connect(function() Tween(Container, {BackgroundColor3 = Theme.ElementBg}, TweenInfo_Fast) end)
            function ColorObj:Set(color)
                currentColor = color
                hue, sat, val = Color3.toHSV(color)
                UpdateColor()
            end
            function ColorObj:Get() return currentColor end
            return ColorObj
        end

        return Tab
    end

    return WindowObj
end

return PaidLibrary
