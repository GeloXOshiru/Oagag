    })
    msgLbl.Size = UDim2.new(1, 0, 0, msgLbl.TextBounds.Y + 2)
    Tween(notif, {Size = UDim2.new(1, 0, 0, 22 + msgLbl.TextBounds.Y + 22)}, TweenInfo_Default)
    local progressBg = Make("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
