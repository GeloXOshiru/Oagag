                if pickerOpen then
                    Tween(Container, {Size = UDim2.new(1, 0, 0, 32 + 144)}, TweenInfo_Default)
                    Tween(PickerPanel, {Size = UDim2.new(1, 0, 0, 140)}, TweenInfo_Default)
