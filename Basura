-- ══════════════════════════════════════
-- UTILITIES
-- ══════════════════════════════════════
local function Tween(obj, props, info)
    TweenService:Create(obj, info or TweenInfo_Default, props):Play()
end

local function AddCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 6)
    c.Parent = parent
    return c
end

local function AddStroke(parent, color, thickness, transparency)
    local old = parent:FindFirstChildOfClass("UIStroke")
    if old then old:Destroy() end
    local s = Instance.new("UIStroke")
    s.Color = color or Theme.Border
    s.Thickness = thickness or 1.2
    s.Transparency = transparency or 0.3
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function AddGradient(parent, c0, c1, rotation)
    local g = Instance.new("UIGradient")
    g.Color = ColorSequence.new(c0, c1)
    g.Rotation = rotation or 90
    g.Parent = parent
    return g
end

local function AddPadding(parent, top, bottom, left, right)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 6)
    p.PaddingBottom = UDim.new(0, bottom or 6)
    p.PaddingLeft   = UDim.new(0, left   or 8)
    p.PaddingRight  = UDim.new(0, right  or 8)
    p.Parent = parent
    return p
end

local function AddListLayout(parent, padding, direction)
    local l = Instance.new("UIListLayout")
    l.Padding = UDim.new(0, padding or 6)
    l.FillDirection = direction or Enum.FillDirection.Vertical
    l.SortOrder = Enum.SortOrder.LayoutOrder
    l.HorizontalAlignment = Enum.HorizontalAlignment.Center
    l.Parent = parent
    return l
end

local function Make(class, props)
    local obj = Instance.new(class)
    for k, v in pairs(props) do obj[k] = v end
    return obj
end

-- ══════════════════════════════════════
-- PARTICLES
-- ══════════════════════════════════════
local function SpawnParticles(parent)
    task.spawn(function()
        while parent and parent.Parent do
            local particle = Make("Frame", {
                Size = UDim2.new(0, math.random(2, 5), 0, math.random(2, 5)),
                Position = UDim2.new(math.random(0, 100)/100, 0, 1, 0),
                BackgroundColor3 = math.random(1, 2) == 1
                    and Color3.fromRGB(255, math.random(180, 215), 0)
                    or Color3.fromRGB(200, 0, 0),
                BackgroundTransparency = 0.3,
                BorderSizePixel = 0,
                ZIndex = 2,
                Parent = parent,
            })
            AddCorner(particle, 999)
            local duration = math.random(15, 35) / 10
            Tween(particle, {
                Position = UDim2.new(
                    particle.Position.X.Scale + math.random(-10, 10)/100,
                    0, -0.1, 0
                ),
                BackgroundTransparency = 1,
                Size = UDim2.new(0, math.random(1, 3), 0, math.random(1, 3))
            }, TweenInfo.new(duration, Enum.EasingStyle.Sine))
            task.delay(duration, function()
                if particle and particle.Parent then
                    particle:Destroy()
                end
            end)
            task.wait(math.random(5, 15) / 100)
        end
    end)
end

-- ══════════════════════════════════════
-- RIPPLE
-- ══════════════════════════════════════
local function Ripple(button, color)
    local ripple = Make("Frame", {
        Size = UDim2.new(0, 0, 0, 0),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        BackgroundColor3 = color or Color3.fromRGB(255, 215, 0),
        BackgroundTransparency = 0.6,
        ZIndex = button.ZIndex + 5,
        Parent = button,
    })
    AddCorner(ripple, 999)
    local size = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.2
    Tween(ripple, {
        Size = UDim2.new(0, size, 0, size),
        BackgroundTransparency = 1
    }, TweenInfo_Slow)
    task.delay(0.35, function() if ripple and ripple.Parent then ripple:Destroy() end end)
end

-- ══════════════════════════════════════
-- GLOW PULSE
-- ══════════════════════════════════════
local function StartGlowPulse(stroke)
    task.spawn(function()
        while stroke and stroke.Parent do
            Tween(stroke, {Transparency = 0.0}, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut))
            task.wait(0.8)
            Tween(stroke, {Transparency = 0.6}, TweenInfo.new(0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut))
            task.wait(0.8)
        end
    end)
end

