            if activeTab then
                Tween(activeTab.btn, {BackgroundColor3 = Theme.TabInactive, TextColor3 = Theme.TabTextDim}, TweenInfo_Fast)
                activeTab.page.Visible = false
            end
            activeTab = {btn = TabBtn, page = TabPage}
            Tween(TabBtn, {BackgroundColor3 = Theme.TabActive, TextColor3 = Theme.TabText}, TweenInfo_Fast)
            TabPage.Visible = true
        end

        TabBtn.MouseButton1Click:Connect(SelectTab)
        TabBtn.MouseEnter:Connect(function()
            if activeTab and activeTab.btn ~= TabBtn then
                Tween(TabBtn, {BackgroundColor3 = Theme.ElementHover}, TweenInfo_Fast)
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if activeTab and activeTab.btn ~= TabBtn then
                Tween(TabBtn, {BackgroundColor3 = Theme.TabInactive}, TweenInfo_Fast)
            end
        end)

