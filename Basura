local NotifHolder = nil
local function InitNotifHolder()
    if NotifHolder and NotifHolder.Parent then return end
    local ok, cg = pcall(function() return CoreGui end)
    local gui = Make("ScreenGui", {
        Name = "PaidNotifGui",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = ok and cg or LocalPlayer.PlayerGui,
    })
    NotifHolder = Make("Frame", {
        Size = UDim2.new(0, 300, 1, 0),
        Position = UDim2.new(1, -315, 0, 0),
        BackgroundTransparency = 1,
        Parent = gui,
    })
    AddListLayout(NotifHolder, 8)
    local pad = Instance.new("UIPadding")
    pad.PaddingTop = UDim.new(0, 20)
    pad.Parent = NotifHolder
end

local function Notify(title, message, duration)
    InitNotifHolder()
    duration = duration or 4
    local notif = Make("Frame", {
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = Theme.NotifBg,
        ClipsDescendants = true,
        Parent = NotifHolder,
    })
    AddCorner(notif, 8)
    local stroke = AddStroke(notif, Theme.Gold, 1.5, 0.2)
    StartGlowPulse(stroke)
    AddGradient(notif, Theme.TitleBar, Theme.Background, 135)

    local goldBar = Make("Frame", {
        Size = UDim2.new(0, 3, 1, 0),
        BackgroundColor3 = Theme.Gold,
        BorderSizePixel = 0,
        Parent = notif,
    })
    AddCorner(goldBar, 3)

    local inner = Make("Frame", {
        Size = UDim2.new(1, -15, 1, 0),
        Position = UDim2.new(0, 12, 0, 0),
        BackgroundTransparency = 1,
        Parent = notif,
    })
    AddPadding(inner, 8, 8, 4, 4)

    Make("TextLabel", {
        Size = UDim2.new(1, 0, 0, 18),
        BackgroundTransparency = 1,
        Text = "👑 " .. (title or "Notification"),
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextColor3 = Theme.Gold,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = inner,
    })
    local msgLbl = Make("TextLabel", {
        Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, 22),
        BackgroundTransparency = 1,
        Text = message or "",
        Font = Enum.Font.Gotham,
        TextSize = 12,
        TextColor3 = Theme.TextDim,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true,
        Parent = inner,
    })
    msgLbl.Size = UDim2.new(1, 0, 0, msgLbl.TextBounds.Y + 2)
    local totalH = 22 + msgLbl.TextBounds.Y + 22
    Tween(notif, {Size = UDim2.new(1, 0, 0, totalH)}, TweenInfo_Default)

    local pb = Make("Frame", {
        Size = UDim2.new(1, 0, 0, 2),
        Position = UDim2.new(0, 0, 1, -2),
        BackgroundColor3 = Theme.AccentDark,
        BorderSizePixel = 0,
        Parent = notif,
    })
    local pf = Make("Frame", {
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = Theme.Gold,
        BorderSizePixel = 0,
        Parent = pb,
    })
    Tween(pf, {Size = UDim2.new(0, 0, 1, 0)}, TweenInfo.new(duration, Enum.EasingStyle.Linear))
    task.delay(duration, function()
        Tween(notif, {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0)}, TweenInfo_Default)
        task.delay(0.25, function() if notif and notif.Parent then notif:Destroy() end end)
    end)
end

