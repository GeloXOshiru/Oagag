                currentKey = key
                KeyBtn.Text = key == Enum.KeyCode.Unknown and "None" or key.Name
                KeyBtn.TextColor3 = Theme.TextAccent
                binding = false
            end
            KeyBtn.MouseButton1Click:Connect(function()
                if binding then return end
                binding = true
                KeyBtn.Text = "..."
                KeyBtn.TextColor3 = Theme.Text
                local conn
                conn = UserInputService.InputBegan:Connect(function(input, processed)
                    if not processed then
                        SetKey(input.KeyCode)
                        conn:Disconnect()
                    end
                end)
            end)
            UserInputService.InputBegan:Connect(function(input, processed)
                if not processed and input.KeyCode == currentKey and not binding then
                    pcall(callback, currentKey)
                end
            end)
            Row.MouseEnter:Connect(function() Tween(Row, {BackgroundColor3 = Theme.ElementHover}, TweenInfo_Fast) end)
            Row.MouseLeave:Connect(function() Tween(Row, {BackgroundColor3 = Theme.ElementBg}, TweenInfo_Fast) end)
            function KeyObj:Set(key) SetKey(key) end
            function KeyObj:Get() return currentKey end
            return KeyObj
        end

