                Size = UDim2.new(0, 14, 0, 14),
                AnchorPoint = Vector2.new(0.5, 0.5),
                Position = UDim2.new((value - min) / (max - min), 0, 0.5, 0),
                BackgroundColor3 = Color3.fromRGB(255, 220, 220),
                BorderSizePixel = 0,
                ZIndex = 6,
                Parent = TrackBg,
            })
            AddCorner(SliderKnob, 999)
            AddStroke(SliderKnob, Theme.AccentBright, 1.5, 0.2)
            local SliderObj = {}
            local function UpdateSlider(v)
                v = math.clamp(math.floor(v), min, max)
                value = v
                local alpha = (v - min) / (max - min)
                Tween(TrackFill, {Size = UDim2.new(alpha, 0, 1, 0)}, TweenInfo_Fast)
                Tween(SliderKnob, {Position = UDim2.new(alpha, 0, 0.5, 0)}, TweenInfo_Fast)
                ValueLabel.Text = tostring(v)
                pcall(callback, v)
            end
            TrackBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSlider = true
                    local alpha = math.clamp((input.Position.X - TrackBg.AbsolutePosition.X) / TrackBg.AbsoluteSize.X, 0, 1)
                    UpdateSlider(min + alpha * (max - min))
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then draggingSlider = false end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if draggingSlider and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local alpha = math.clamp((input.Position.X - TrackBg.AbsolutePosition.X) / TrackBg.AbsoluteSize.X, 0, 1)
                    UpdateSlider(min + alpha * (max - min))
                end
            end)
            function SliderObj:Set(v) UpdateSlider(v) end
            function SliderObj:Get() return value end
            return SliderObj
        end

