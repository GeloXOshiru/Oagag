                BorderSizePixel = 0,
                ZIndex = 17,
                Parent = SatValFrame,
            })
            AddCorner(SVKnob, 999)
            AddStroke(SVKnob, Color3.fromRGB(0, 0, 0), 1.5, 0)
            local HueBar = Make("ImageLabel", {
                Size = UDim2.new(0, 14, 0, 100),
                Position = UDim2.new(1, -20, 0, 8),
                Image = "rbxassetid://3641079629",
                BorderSizePixel = 0,
                ZIndex = 16,
                Parent = PickerPanel,
            })
            AddCorner(HueBar, 4)
            local HueKnob = Make("Frame", {
                Size = UDim2.new(1, 4, 0, 3),
                Position = UDim2.new(0, -2, hue, 0),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel = 0,
                ZIndex = 17,
                Parent = HueBar,
            })
            AddCorner(HueKnob, 2)
            local HexLabel = Make("TextLabel", {
                Size = UDim2.new(1, -12, 0, 20),
                Position = UDim2.new(0, 6, 0, 114),
                BackgroundColor3 = Theme.ElementBg,
                BorderSizePixel = 0,
                Text = string.format("#%02X%02X%02X", math.floor(currentColor.R*255), math.floor(currentColor.G*255), math.floor(currentColor.B*255)),
                Font = Enum.Font.Code,
                TextSize = 12,
                TextColor3 = Theme.TextDim,
                ZIndex = 16,
                Parent = PickerPanel,
            })
            AddCorner(HexLabel, 4)
            local ColorObj = {}
            local function UpdateColor()
                currentColor = Color3.fromHSV(hue, sat, val)
                ColorPreview.BackgroundColor3 = currentColor
                SatValFrame.BackgroundColor3 = Color3.fromHSV(hue, 1, 1)
                SVKnob.Position = UDim2.new(sat, 0, 1 - val, 0)
                HueKnob.Position = UDim2.new(0, -2, hue, 0)
                HexLabel.Text = string.format("#%02X%02X%02X", math.floor(currentColor.R*255), math.floor(currentColor.G*255), math.floor(currentColor.B*255))
                pcall(callback, currentColor)
            end
            local draggingSV = false
            SatValFrame.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = true
                    sat = math.clamp((input.Position.X - SatValFrame.AbsolutePosition.X) / SatValFrame.AbsoluteSize.X, 0, 1)
                    val = 1 - math.clamp((input.Position.Y - SatValFrame.AbsolutePosition.Y) / SatValFrame.AbsoluteSize.Y, 0, 1)
                    UpdateColor()
                end
            end)
            local draggingHue = false
            HueBar.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingHue = true
                    hue = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
                    UpdateColor()
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = false
                    draggingHue = false
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement then
                    if draggingSV then
                        sat = math.clamp((input.Position.X - SatValFrame.AbsolutePosition.X) / SatValFrame.AbsoluteSize.X, 0, 1)
                        val = 1 - math.clamp((input.Position.Y - SatValFrame.AbsolutePosition.Y) / SatValFrame.AbsoluteSize.Y, 0, 1)
                        UpdateColor()
                    elseif draggingHue then
                        hue = math.clamp((input.Position.Y - HueBar.AbsolutePosition.Y) / HueBar.AbsoluteSize.Y, 0, 1)
                        UpdateColor()
                    end
                end
            end)
            Header.MouseButton1Click:Connect(function()
