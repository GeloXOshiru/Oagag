        Position = UDim2.new(1, -34, 0.5, -11),
        BackgroundColor3 = Theme.AccentDark,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        Text = "—",
        Font = Enum.Font.GothamBold,
        TextSize = 13,
        TextColor3 = Theme.Gold,
        ZIndex = 7,
        Parent = TitleBar,
    })
    AddCorner(MinBtn, 5)
    AddStroke(MinBtn, Theme.Gold, 1, 0.5)

    -- ── TAB BAR ──
    local TabBar = Make("Frame", {
        Size = UDim2.new(1, 0, 0, 32),
        Position = UDim2.new(0, 0, 0, 40),
        BackgroundColor3 = Theme.BackgroundAlt,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        ZIndex = 5,
        Parent = Window,
    })
    Make("Frame", {
        Size = UDim2.new(1, 0, 0, 1),
        Position = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = Theme.Gold,
        BackgroundTransparency = 0.7,
        BorderSizePixel = 0,
        ZIndex = 6,
        Parent = TabBar,
    })

    local TabScroll = Make("ScrollingFrame", {
        Size = UDim2.new(1, -10, 1, 0),
        Position = UDim2.new(0, 5, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 0,
        CanvasSize = UDim2.new(0, 0, 1, 0),
        ScrollingDirection = Enum.ScrollingDirection.X,
        ZIndex = 6,
        Parent = TabBar,
    })
    local TabButtonHolder = Make("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = 6,
        Parent = TabScroll,
    })
    local TabLayout = AddListLayout(TabButtonHolder, 4, Enum.FillDirection.Horizontal)
    TabLayout.VerticalAlignment = Enum.VerticalAlignment.Center

    -- ── CONTENT AREA ──
    local ContentArea = Make("Frame", {
        Size = UDim2.new(1, 0, 1, -74),
        Position = UDim2.new(0, 0, 0, 74),
        BackgroundTransparency = 1,
        ClipsDescendants = true,
        ZIndex = 5,
        Parent = Window,
    })

    -- ── AUTO RESIZE WINDOW ──
    local function ResizeWindow()
        local contentH = 0
        if ContentArea then
            for _, page in ipairs(ContentArea:GetChildren()) do
                if page:IsA("ScrollingFrame") and page.Visible then
                    local layout = page:FindFirstChildOfClass("UIListLayout")
                    if layout then
                        contentH = layout.AbsoluteContentSize.Y
                    end
                end
            end
        end
        local newH = math.clamp(contentH + 74 + 20, 200, 600)
        Tween(Window, {Size = UDim2.new(0, 520, 0, newH)}, TweenInfo_Default)
        Shadow.Size = UDim2.new(0, 560, 0, newH + 40)
    end

    -- ── DRAGGING ──
    local dragging, dragStart, startPos = false, nil, nil
    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = Window.Position
        end
    end)
    TitleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            Window.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            Shadow.Position = UDim2.new(Window.Position.X.Scale, Window.Position.X.Offset - 20, Window.Position.Y.Scale, Window.Position.Y.Offset - 20)
        end
    end)

    -- ── MINIMIZE ──
    local minimized = false
    MinBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            Tween(Window, {Size = UDim2.new(0, 520, 0, 40)}, TweenInfo_Default)
            MinBtn.Text = "+"
        else
            ResizeWindow()
            MinBtn.Text = "—"
        end
    end)

    -- ── TOGGLE KEY ──
    UserInputService.InputBegan:Connect(function(input, processed)
        if not processed and input.KeyCode == toggleKey then
            ScreenGui.Enabled = not ScreenGui.Enabled
        end
    end)

    -- ══════════════════════════════════════
    -- TAB + ELEMENT SYSTEM
    -- ══════════════════════════════════════
    local tabs = {}
    local activeTab = nil
    local WindowObj = {}

    function WindowObj:Notify(t, m, d) Notify(t, m, d) end

    function WindowObj:AddTab(name)
        local TabBtn = Make("TextButton", {
            Size = UDim2.new(0, 80, 0, 24),
            BackgroundColor3 = Theme.TabInactive,
            BackgroundTransparency = 0.5,
            BorderSizePixel = 0,
            Text = name,
            Font = Enum.Font.GothamBold,
            TextSize = 12,
            TextColor3 = Theme.TabTextDim,
            AutoButtonColor = false,
            ZIndex = 7,
            Parent = TabButtonHolder,
        })
        AddCorner(TabBtn, 5)

        task.defer(function()
            TabBtn.Size = UDim2.new(0, TabBtn.TextBounds.X + 22, 0, 24)
            local total = 0
            for _, v in ipairs(TabButtonHolder:GetChildren()) do
                if v:IsA("TextButton") then total = total + v.AbsoluteSize.X + 4 end
            end
            TabButtonHolder.Size = UDim2.new(0, total, 1, 0)
            TabScroll.CanvasSize = UDim2.new(0, total, 1, 0)
        end)

        local TabPage = Make("ScrollingFrame", {
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.Gold,
            ScrollBarImageTransparency = 0.4,
            CanvasSize = UDim2.new(0, 0, 0, 0),
            Visible = false,
            ZIndex = 6,
            Parent = ContentArea,
        })
        AddPadding(TabPage, 8, 8, 10, 10)
        local PageLayout = AddListLayout(TabPage, 6)
        PageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            TabPage.CanvasSize = UDim2.new(0, 0, 0, PageLayout.AbsoluteContentSize.Y + 16)
            if not minimized then ResizeWindow() end
        end)

        local function SelectTab()
            if activeTab then
                Tween(activeTab.btn, {BackgroundColor3 = Theme.TabInactive, TextColor3 = Theme.TabTextDim, BackgroundTransparency = 0.5}, TweenInfo_Fast)
                activeTab.page.Visible = false
            end
            activeTab = {btn = TabBtn, page = TabPage}
            Tween(TabBtn, {BackgroundColor3 = Theme.TabActive, TextColor3 = Theme.TabText, BackgroundTransparency = 0}, TweenInfo_Fast)
            TabPage.Visible = true
            if not minimized then ResizeWindow() end
        end

        TabBtn.MouseButton1Click:Connect(function()
            Ripple(TabBtn, Theme.Gold)
            SelectTab()
        end)
        TabBtn.MouseEnter:Connect(function()
            if not (activeTab and activeTab.btn == TabBtn) then
                Tween(TabBtn, {BackgroundColor3 = Theme.ElementHover, BackgroundTransparency = 0.3}, TweenInfo_Fast)
            end
        end)
        TabBtn.MouseLeave:Connect(function()
            if not (activeTab and activeTab.btn == TabBtn) then
                Tween(TabBtn, {BackgroundColor3 = Theme.TabInactive, BackgroundTransparency = 0.5}, TweenInfo_Fast)
            end
        end)

        if #tabs == 0 then SelectTab() end
        table.insert(tabs, {btn = TabBtn, page = TabPage})

        local Tab = {}
        function Tab:Show() SelectTab() end

        -- ── SECTION ──
        function Tab:AddSection(text)
            local Section = Make("Frame", {
                Size = UDim2.new(1, 0, 0, 26),
                BackgroundTransparency = 1,
                ZIndex = 7,
                Parent = TabPage,
            })
            Make("Frame", {
                Size = UDim2.new(1, 0, 0, 1),
                Position = UDim2.new(0, 0, 0.5, 0),
                BackgroundColor3 = Theme.Gold,
                BackgroundTransparency = 0.6,
                BorderSizePixel = 0,
                ZIndex = 7,
                Parent = Section,
            })
            Make("TextLabel", {
                Size = UDim2.new(0, 0, 1, 0),
                AnchorPoint = Vector2.new(0.5, 0),
                Position = UDim2.new(0.5, 0, 0, 0),
                BackgroundColor3 = Theme.Background,
                BorderSizePixel = 0,
                Font = Enum.Font.GothamBold,
                Text = "  👑 " .. text .. "  ",
                TextSize = 11,
                TextColor3 = Theme.Gold,
                AutomaticSize = Enum.AutomaticSize.X,
                ZIndex = 8,
                Parent = Section,
            })
            return Section
        end

        -- ── LABEL ──
        function Tab:AddLabel(text)
            local lbl = Make("TextLabel", {
                Size = UDim2.new(1, 0, 0, 20),
                BackgroundTransparency = 1,
                Text = text or "",
                Font = Enum.Font.Gotham,
                TextSize = 13,
                TextColor3 = Theme.TextDim,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 7,
                Parent = TabPage,
            })
            return lbl
        end

        -- ── BUTTON ──
        function Tab:AddButton(text, callback)
            callback = callback or function() end
            local Btn = Make("TextButton", {
                Size = UDim2.new(1, 0, 0, 34),
                BackgroundColor3 = Theme.ElementBg,
                BorderSizePixel = 0,
