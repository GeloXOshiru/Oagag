                Parent = Row,
            })
            local Track = Make("Frame", {
                Size = UDim2.new(0, 36, 0, 18),
                Position = UDim2.new(1, -46, 0.5, -9),
                BackgroundColor3 = state and Theme.ToggleOn or Theme.ToggleOff,
                BorderSizePixel = 0,
                ZIndex = 4,
                Parent = Row,
            })
            AddCorner(Track, 9)
            AddStroke(Track, Theme.Border, 1, 0.3)
            local Knob = Make("Frame", {
                Size = UDim2.new(0, 12, 0, 12),
                Position = state and UDim2.new(1, -15, 0.5, -6) or UDim2.new(0, 3, 0.5, -6),
                BackgroundColor3 = Color3.fromRGB(255, 220, 220),
                BorderSizePixel = 0,
                ZIndex = 5,
                Parent = Track,
            })
            AddCorner(Knob, 999)
            local ToggleObj = {}
            local function SetState(val)
                state = val
                if state then
                    Tween(Track, {BackgroundColor3 = Theme.ToggleOn}, TweenInfo_Fast)
                    Tween(Knob, {Position = UDim2.new(1, -15, 0.5, -6)}, TweenInfo_Fast)
                else
                    Tween(Track, {BackgroundColor3 = Theme.ToggleOff}, TweenInfo_Fast)
                    Tween(Knob, {Position = UDim2.new(0, 3, 0.5, -6)}, TweenInfo_Fast)
                end
                pcall(callback, state)
            end
            Row.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then SetState(not state) end
            end)
            Row.MouseEnter:Connect(function() Tween(Row, {BackgroundColor3 = Theme.ElementHover}, TweenInfo_Fast) end)
            Row.MouseLeave:Connect(function() Tween(Row, {BackgroundColor3 = Theme.ElementBg}, TweenInfo_Fast) end)
            function ToggleObj:Set(val) SetState(val) end
            function ToggleObj:Get() return state end
            return ToggleObj
        end

